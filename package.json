{
  "name": "@openclaw/obsidian-graph-memory",
  "version": "0.1.0",
  "description": "Local-first graph memory compiler and retrieval extension for Obsidian vaults in OpenClaw.",
  "type": "module",
  "bin": {
    "openclaw-obsidian-memory": "./bin/openclaw-obsidian-memory.js"
  },
  "scripts": {
